rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsExistingResource(fieldName) {
      return isSignedIn() && resource.data[fieldName] == request.auth.uid;
    }

    function hasValidSpeechVisibility() {
      return request.resource.data.visibility in ["private", "public"];
    }

    function canReadSpeech() {
      return isSignedIn()
        && (
          resource.data.visibility == "public"
          || resource.data.creatorId == request.auth.uid
        );
    }

    function isSpeechReportUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "reported",
          "updatedAt"
        ])
        && request.resource.data.reported == true;
    }

    function hasValidDisplayName() {
      return request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 30;
    }

    function keepsExistingDisplayName() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        "displayName"
      ]);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && hasValidDisplayName();
      allow update: if isOwner(userId) && keepsExistingDisplayName();
    }

    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if ownsExistingResource("followerId");
    }

    match /tabroomLinks/{linkId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /tabroomImports/{importId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // Authentication cookies are encrypted and managed exclusively by Admin SDK
    // callables. They must never be exposed through the client Firestore SDK.
    match /tabroomSessions/{userId} {
      allow read, write: if false;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if ownsExistingResource("authorId");
    }

    match /postComments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;
    }

    match /postReactions/{reactionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    match /userStats/{statsId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    match /speechComments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;
    }

    match /speeches/{speechId} {
      allow read: if canReadSpeech();
      allow create: if isSignedIn()
        && request.resource.data.creatorId == request.auth.uid
        && hasValidSpeechVisibility();
      allow update: if (
          ownsExistingResource("creatorId")
          && hasValidSpeechVisibility()
        )
        || isSpeechReportUpdate();
      allow delete: if ownsExistingResource("creatorId");
    }

    function debateData(debateId) {
      return get(/databases/$(database)/documents/debates/$(debateId)).data;
    }

    function isDebateParticipant(debateId) {
      return isSignedIn()
        && request.auth.uid in debateData(debateId).participantIds;
    }

    // Comments are allowed only when the debate opted in, and — while the debate
    // is still running — only for spectators (non-participants). Once completed,
    // anyone signed in may comment.
    function debateCommentsAllowed(debateId) {
      let debate = debateData(debateId);
      return debate.commentsEnabled == true
        && (
          debate.status == "Completed"
          || !(request.auth.uid in debate.participantIds)
        );
    }

    match /debates/{debateId} {
      // Public debates are readable to any signed-in user; private debates are
      // readable to their participants and creator. (Whole-collection listeners
      // still require a broad read, so listing stays gated to signed-in users.)
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /matchRequests/{requestId} {
      allow read, create, update: if isSignedIn();
    }

    match /debateMessages/{messageId} {
      allow read: if isSignedIn();
      // Only debate participants may post to the participant chat.
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && isDebateParticipant(request.resource.data.debateId);
    }

    match /debateComments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && debateCommentsAllowed(request.resource.data.debateId);
    }

    match /debateReactions/{reactionId} {
      allow read: if isSignedIn();
      // A reaction document is writable only by its owning user.
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.category in ["Case Building", "Rebuttal", "Research", "Delivery"]
        && request.resource.data.description is string
        && request.resource.data.curatedBy is string
        && request.resource.data.level in ["Starter", "Growth", "Advanced"];
      allow update: if isSignedIn();
    }

    match /channels/{channelId} {
      allow read: if true;
      allow create, update: if isSignedIn();
    }

    match /debateChatReads/{readId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    match /channelMemberships/{membershipId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if ownsExistingResource("userId");
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }
  }
}
